{
  "name": "cmms",
  "version": "1.0.0",
  "description": "Real-time crypto market monitoring system",
  "main": "src/api/server.js",
  "scripts": {
    "kafka:init": "node src/kafka/admin.js",
    "producer:binance": "node src/ingestion/binanceProducer.js",
    "producer:coinbase": "node src/ingestion/coinbaseProducer.js",
    "consumer:1": "node src/consumers/consumer1-normalizer.js",
    "consumer:2": "node src/consumers/consumer2-aggregator.js",
    "consumer:3": "node src/consumers/consumer3-anomaly.js",
    "api": "node src/api/server.js",
    "dev": "node scripts/start.js",
    "start": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop ecosystem.config.js",
    "stop:all": "pm2 stop ecosystem.config.js && docker-compose stop",
    "restart": "pm2 restart ecosystem.config.js",
    "reload": "pm2 reload ecosystem.config.js",
    "logs": "pm2 logs",
    "status": "pm2 status",
    "flush": "pm2 flush"
  },
  "dependencies": {
    "kafkajs": "^2.2.4",
    "mongoose": "^8.3.4",
    "ws": "^8.17.0",
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "dotenv": "^16.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
